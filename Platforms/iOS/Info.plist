<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIDesignRequiresCompatibility</key>
	<true/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>
	<key>CFBundleIdentifier</key>
	<string>dk.au.wodiacollectstation</string>
	<key>CFBundleShortVersionString</key>
	<string>1</string>

	<!--Description of the Bluetooth request message (required on iOS 10, deprecated)-->
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>In need to ask for Bluetooth</string>

	<!--Description of the Bluetooth request message (required on iOS 13)-->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>I need to use Bluetooth always</string>

	<key>NSLocationAlwaysUsageDescription</key>
	<string>We need to have location always on</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>We need to have location always on while in use</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>We need to have location always on in order to be able to use the Bluetooth connection. </string>
	
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
		<string>fetch</string>
		<string>location</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
